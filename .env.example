# Copy to .env and edit. Never commit .env. All keys use the MF_ prefix.
MF_LOG_LEVEL=INFO

# Data source: any daily FRED series id (keyless). Examples: SP500, DGS10.
MF_SERIES_ID=SP500
MF_START_DATE=2015-01-01

# Forecasting / validation (optional overrides).
# MF_HORIZON=5
# MF_N_SPLITS=5
# MF_TEST_SIZE=40
